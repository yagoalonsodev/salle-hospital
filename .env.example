# =============================================================================
# laSalle Health Center — plantilla de entorno
# =============================================================================
# Uso:  cp .env.example .env
# Nunca commitees .env. Valores de abajo = desarrollo local únicamente.
#
# DATABASE_URL debe usar el mismo POSTGRES_USER y POSTGRES_PASSWORD de abajo.
# AIRFLOW_DB_PASSWORD debe coincidir con infra/postgres/init-airflow-db.sql
# =============================================================================

# --- PostgreSQL (aplicación hospital) ----------------------------------------
POSTGRES_USER=salle
POSTGRES_PASSWORD=salle_secret
POSTGRES_DB=salle_hospital

# Cadena completa (scripts, pipeline, api, ml) — host "postgres" dentro de Docker
DATABASE_URL=postgresql://salle:salle_secret@postgres:5432/salle_hospital

# Desde el host (psql, DBeaver): localhost en lugar de postgres
# DATABASE_URL=postgresql://salle:salle_secret@localhost:5432/salle_hospital

# --- PostgreSQL (metadatos Apache Airflow) -----------------------------------
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret
AIRFLOW_DB_NAME=airflow

# --- Airflow Web UI (http://localhost:8081) ------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=Admin123.

# --- MinIO (S3-compatible) — API :9000, consola :9001 ------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=xray-images
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# --- Servicios HTTP internos (Docker network) --------------------------------
API_URL=http://api:8000
ML_SERVICE_URL=http://ml:8001
API_HOST=0.0.0.0
API_PORT=8000

# --- Apache Spark ------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077

# --- Rutas de datos (contenedores; en host usar ./data) ------------------------
DATA_ROOT=/opt/data
PROCESSED_MANIFEST_DIR=/opt/data/processed/manifest
RAW_ROOT=/opt/data/raw/covid19_vs_pneumonia
FEATURES_ROOT=/opt/data/processed/features
FEATURES_VERSION=v1
WATCH_INCOMING_DIR=/opt/data/raw/covid19_vs_pneumonia/incoming
WATCHER_STATE_DIR=/opt/data/processed/watcher
AIRFLOW_SCRIPTS_DIR=/opt/scripts

# --- Pipeline: ingesta imágenes ------------------------------------------------
UPLOAD_MINIO=true
MAX_UPLOAD=0
MIN_IMAGE_BYTES=500
PIPELINE_CONTAINER=salle-pipeline

# --- Pipeline: preprocesado ML (Día 3) -----------------------------------------
IMAGE_SIZE=224
VAL_RATIO=0.15
RANDOM_SEED=42
PREPROCESS_PARTITIONS=8
PREPROCESS_LIMIT=0

# --- Watcher de nuevas imágenes ----------------------------------------------
WATCHER_DEBOUNCE_SEC=2.0

# --- Reentrenamiento nocturno (DAG salle_nightly_retrain, 01:00) ----------------
NIGHTLY_RETRAIN_ENABLED=true
NIGHTLY_HEAD_EPOCHS=5
NIGHTLY_FINETUNE_EPOCHS=3

# --- MongoDB (logs centralizados) — en dev mismas credenciales que Postgres ----
MONGO_USER=salle
MONGO_PASSWORD=salle_secret
MONGO_DB=salle_logs
MONGODB_URI=mongodb://salle:salle_secret@mongodb:27017/salle_logs?authSource=admin
MONGO_LOG_ENABLED=true
LOG_SYNC_INTERVAL_SEC=60

# --- Airflow / Docker (opcional) -----------------------------------------------
# AIRFLOW_UID=50000
# _PIP_ADDITIONAL_REQUIREMENTS=docker>=7.0.0
