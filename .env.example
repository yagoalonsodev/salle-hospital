# PostgreSQL (aplicación)
POSTGRES_USER=salle
POSTGRES_PASSWORD=salle_secret
POSTGRES_DB=salle_hospital

# PostgreSQL (metadatos Airflow — creado por infra/postgres/init-airflow-db.sql)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret
AIRFLOW_DB_NAME=airflow

# Airflow standalone — UI http://localhost:8081
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=Admin123.

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=xray-images

# API / ML / Dashboard
API_HOST=0.0.0.0
API_PORT=8000
ML_SERVICE_URL=http://ml:8001
DATABASE_URL=postgresql://salle:salle_secret@postgres:5432/salle_hospital

# Spark
SPARK_MASTER_URL=spark://spark-master:7077

# Pipeline / MinIO — 0 = subir todas las imágenes válidas (sin límite)
MAX_UPLOAD=0

# Permisos volúmenes Airflow en Linux (opcional)
# AIRFLOW_UID=50000
